#!/usr/bin/env bash
# WOLF_DESC: Buscar cuentas asociadas a un email (Holehe)
set -euo pipefail

BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Intentamos usar el holehe real (si lo tienes en venv o instalado)
HOLEHE_CMD=""
if [[ -x "$BASE_DIR/.venv/bin/holehe" ]]; then
  HOLEHE_CMD="$BASE_DIR/.venv/bin/holehe"
elif command -v holehe >/dev/null 2>&1; then
  HOLEHE_CMD="$(command -v holehe)"
else
  # Si tu holehe real está en otra ruta, dímelo y lo ajustamos
  echo "[!] Holehe no está instalado o no se encuentra."
  echo "    Prueba: pipx install holehe  o  pip install holehe"
  exit 1
fi

EMAIL="${1:-}"
if [[ -z "$EMAIL" ]]; then
  read -r -p "Email a buscar: " EMAIL
fi

EMAIL="${EMAIL// /}"
if [[ -z "$EMAIL" ]]; then
  echo "[!] Email vacío."
  exit 1
fi

TS="$(date +%Y%m%d_%H%M%S)"
SAFE_EMAIL="${EMAIL//@/_at_}"
OUT_DIR="$BASE_DIR/reports/holehe/$SAFE_EMAIL"
mkdir -p "$OUT_DIR"

LOG="$OUT_DIR/${TS}.log"
URLS="$OUT_DIR/${TS}_urls.txt"
CHECK="$OUT_DIR/${TS}_checklist.txt"

echo "[*] Guardando log en: $LOG"
"$HOLEHE_CMD" "$EMAIL" 2>&1 | tee "$LOG"

# Extrae URLs (si las hay) para revisarlas rápido
grep -Eo 'https?://[^ )]+' "$LOG" | sort -u > "$URLS" || true

# Checklist simple (líneas “interesantes” típicas)
grep -Ei 'found|exists|match|account|success|\[\+\]|\[\*\]|\[!\]|http' "$LOG" > "$CHECK" || true

echo "[OK] URLs:      $URLS"
echo "[OK] Checklist: $CHECK"






